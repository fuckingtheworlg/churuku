page {
  min-height: 100%;
  background: #f5f7fb;
  color: #1f2937;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  padding: 24rpx;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.btn-primary {
  color: #fff;
  background: #2563eb;
}

.muted {
  color: #64748b;
  font-size: 26rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.field {
  margin-bottom: 24rpx;
}

.label {
  margin-bottom: 10rpx;
  color: #475569;
  font-size: 26rpx;
}

input,
textarea,
picker {
  box-sizing: border-box;
  width: 100%;
  min-height: 80rpx;
  padding: 18rpx;
  border: 1rpx solid #dbe3ef;
  border-radius: 12rpx;
  background: #fff;
}
