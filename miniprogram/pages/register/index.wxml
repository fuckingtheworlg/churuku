<view class="page">
  <view class="card">
    <view class="field">
      <view class="label">姓名</view>
      <input value="{{realName}}" placeholder="请输入真实姓名" bindinput="onNameInput" />
    </view>
    <view class="field">
      <view class="label">部门</view>
      <picker range="{{deptNames}}" value="{{deptIndex}}" bindchange="onDeptChange">
        <view>{{ deptNames[deptIndex] || '请选择部门' }}</view>
      </picker>
    </view>
    <button class="btn-primary" loading="{{loading}}" bindtap="submit">提交审批</button>
  </view>
</view>
