<view class="page" wx:if="{{item}}">
  <view class="card">
    <view class="name">{{item.name}}</view>
    <view class="muted">{{item.spec || '无规格'}} · {{item.category.name || '未分类'}}</view>
    <view class="qty">当前库存：{{item.quantity}} {{item.unit}}</view>
    <view class="muted">存放位置：{{item.location || '未填写'}}</view>
  </view>
  <view class="card usage-card">
    <view class="row">
      <view class="section-title" style="margin:0">设备使用</view>
      <view wx:if="{{usage.ongoing}}" class="status-active">使用中</view>
      <view wx:else class="status-idle">空闲</view>
    </view>
    <view wx:if="{{usage.ongoing}}">
      <view class="muted">使用人：{{usage.ongoing.operatorName}}</view>
      <view class="muted">开始时间：{{usage.ongoing.startedAtText}}</view>
      <view class="muted">本次已用：{{usage.ongoing.durationText}}</view>
    </view>
    <view class="muted">累计使用：{{usage.totalText}}</view>
    <view class="usage-actions">
      <button wx:if="{{!usage.ongoing}}" class="btn-primary" loading="{{usageLoading}}" bindtap="startUsage">开始使用</button>
      <button wx:else loading="{{usageLoading}}" bindtap="endUsage">结束使用</button>
    </view>
  </view>
  <view wx:if="{{usage.recent.length}}" class="section-title">最近使用记录</view>
  <view wx:for="{{usage.recent}}" wx:for-item="row" wx:key="id" class="card usage-row">
    <view class="row">
      <view>{{row.operatorName}}</view>
      <view class="muted">{{row.durationText || '使用中'}}</view>
    </view>
    <view class="muted">开始：{{row.startedAtText}}</view>
    <view class="muted">结束：{{row.endedAtText}}</view>
  </view>
  <view class="section-title">出入库历史记录</view>
  <view wx:for="{{records}}" wx:for-item="record" wx:for-index="recordIndex" wx:key="id" class="card">
    <view class="row">
      <view>{{record.type === 'in' ? '入库' : '出库'}} {{record.displayQuantity}} {{record.displayUnit}}</view>
      <view class="muted">{{record.occurredAtText}}</view>
    </view>
    <view class="muted">项目：{{record.projectName || '-'}}</view>
    <view class="muted">单据明细：{{record.itemSummary}}</view>
    <view class="muted">{{record.operatorName || '未知责任人'}} · {{record.poiName || record.address || '无位置'}}</view>
    <view wx:if="{{record.previewUrls.length}}" class="thumbs">
      <image
        wx:for="{{record.photoUrls}}"
        wx:for-item="photo"
        wx:key="*this"
        class="thumb"
        src="{{photo}}"
        mode="aspectFill"
        data-index="{{recordIndex}}"
        data-current="{{photo}}"
        bindtap="previewImage"
      />
      <image
        wx:if="{{record.signatureUrl}}"
        class="thumb signature-thumb"
        src="{{record.signatureUrl}}"
        mode="aspectFit"
        data-index="{{recordIndex}}"
        data-current="{{record.signatureUrl}}"
        bindtap="previewImage"
      />
    </view>
  </view>
  <view wx:if="{{!records.length}}" class="empty">暂无历史记录</view>
</view>
