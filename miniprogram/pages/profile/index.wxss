.name {
  margin-bottom: 16rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.section-title {
  margin: 30rpx 0 18rpx;
  font-weight: 700;
}

.record-title {
  font-weight: 600;
}

.thumbs {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.thumb {
  width: 132rpx;
  height: 132rpx;
  border-radius: 12rpx;
  background: #f1f5f9;
}

.signature-thumb {
  background: #fff;
  border: 1rpx solid #e2e8f0;
}

.empty {
  padding: 36rpx 0;
  color: #94a3b8;
  text-align: center;
}
