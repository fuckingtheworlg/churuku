.page {
  padding-bottom: 260rpx;
}

.toolbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.toolbar input,
.toolbar .search-input {
  flex: 1;
  background: #fff;
}

.scan-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: #ecfdf5;
  color: #047857;
  border: 1rpx solid #10b981;
  flex: none;
}

.scan-icon-dot {
  width: 28rpx;
  height: 28rpx;
  margin-bottom: 4rpx;
  border: 2rpx solid #047857;
  border-radius: 6rpx;
  position: relative;
}

.scan-icon-dot::after {
  content: '';
  position: absolute;
  top: 50%;
  left: -4rpx;
  right: -4rpx;
  height: 2rpx;
  background: #047857;
}

.scan-icon-text {
  font-size: 20rpx;
  line-height: 1;
}

.tabs {
  display: flex;
  gap: 16rpx;
  margin: 20rpx 0;
  overflow-x: auto;
}

.tab {
  flex: none;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  color: #475569;
}

.tab.active {
  background: #2563eb;
  color: #fff;
}

.name {
  margin-bottom: 12rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.qty {
  color: #2563eb;
  font-size: 34rpx;
  font-weight: 700;
}

.empty {
  padding: 80rpx 0;
  color: #94a3b8;
  text-align: center;
}

.actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  display: flex;
  gap: 20rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -6rpx 20rpx rgba(15, 23, 42, 0.08);
}

.actions button {
  flex: 1;
}
