<view class="page">
  <view class="toolbar">
    <input placeholder="搜索物品名称/规格/位置" value="{{keyword}}" bindinput="onKeyword" confirm-type="search" bindconfirm="load" />
  </view>
  <view class="tabs">
    <view class="tab {{!categoryId ? 'active' : ''}}" bindtap="selectCategory" data-id="">全部</view>
    <view wx:for="{{categories}}" wx:key="id" class="tab {{categoryId === item.id ? 'active' : ''}}" bindtap="selectCategory" data-id="{{item.id}}">{{item.name}}</view>
  </view>
  <view wx:for="{{items}}" wx:key="id" class="card item" bindtap="goDetail" data-id="{{item.id}}">
    <view class="row">
      <view>
        <view class="name">{{item.name}}</view>
        <view class="muted">{{item.spec || '无规格'}} · {{item.location || '未填写位置'}}</view>
      </view>
      <view class="qty">{{item.quantity}} {{item.unit}}</view>
    </view>
  </view>
  <view wx:if="{{!items.length}}" class="empty">暂无库存</view>
  <view class="actions">
    <button class="btn-primary" bindtap="goStock" data-type="in">入库</button>
    <button bindtap="goStock" data-type="out">出库</button>
  </view>
</view>
