<view class="page">
  <view class="card">
    <view class="field">
      <view class="label">类型</view>
      <view class="type">{{type === 'in' ? '入库' : '出库'}}</view>
    </view>
    <view class="field">
      <view class="label">物品</view>
      <picker range="{{itemNames}}" value="{{itemIndex}}" bindchange="onItemChange">
        <view>{{ itemNames[itemIndex] || '请选择物品' }}</view>
      </picker>
    </view>
    <view class="field">
      <view class="label">数量</view>
      <input type="number" value="{{quantity}}" placeholder="请输入数量" bindinput="onQuantity" />
    </view>
    <view class="field">
      <view class="label">位置</view>
      <button bindtap="chooseLocation">选择当前位置/地图位置</button>
      <view wx:if="{{location.address}}" class="location">
        <view>{{location.name}}</view>
        <view class="muted">{{location.address}}</view>
        <view class="muted">{{location.latitude}}, {{location.longitude}}</view>
      </view>
    </view>
    <view class="field">
      <view class="label">拍照</view>
      <button bindtap="choosePhotos">拍照/选择图片</button>
      <view class="photos">
        <image wx:for="{{photos}}" wx:key="*this" src="{{item}}" mode="aspectFill" />
      </view>
    </view>
    <view class="field">
      <view class="label">签字</view>
      <signature-pad id="signature" />
    </view>
    <view class="field">
      <view class="label">日期</view>
      <picker mode="date" value="{{date}}" bindchange="onDate">
        <view>{{date}}</view>
      </picker>
    </view>
    <view class="field">
      <view class="label">备注</view>
      <textarea value="{{note}}" placeholder="可选" bindinput="onNote" />
    </view>
    <button class="btn-primary" loading="{{loading}}" bindtap="submit">提交</button>
  </view>
</view>
