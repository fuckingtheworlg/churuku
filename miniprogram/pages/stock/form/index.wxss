  background: #f8fafc;
}

.photos {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 16rpx;
}

.photos image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
  background: #e2e8f0;
}
